# Copy this to `.env` and fill in real values.

# --- Database ---
# Local dev (SQLite): keep the value below.
# Production: swap to a Postgres URL and change `provider = "sqlite"` -> "postgresql" in prisma/schema.prisma.
DATABASE_URL="file:./dev.db"

# --- Admin auth ---
# The password used to sign in at /admin.
ADMIN_PASSWORD="change-me"

# 32+ character random string used to sign admin session cookies.
# Generate with: openssl rand -hex 32
SESSION_SECRET="please-generate-a-long-random-secret"
